{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/strategic-mirror/connector-registry.schema.json",
  "title": "Connector Registry",
  "type": "object",
  "required": ["connectors"],
  "properties": {
    "connectors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "tier",
          "host",
          "enabled",
          "source_allowlist",
          "read_permissions",
          "write_permissions",
          "approval_required_for",
          "memory_write_behavior",
          "state_write_behavior",
          "secrets_handling",
          "public_safety_notes"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "tier": { "type": "integer", "minimum": 0, "maximum": 5 },
          "host": { "type": "string" },
          "enabled": { "type": "boolean" },
          "source_allowlist": { "type": "array", "items": { "type": "string" } },
          "read_permissions": { "type": "array", "items": { "type": "string" } },
          "write_permissions": { "type": "array", "items": { "type": "string" } },
          "approval_required_for": { "type": "array", "items": { "type": "string" } },
          "memory_write_behavior": { "type": "string" },
          "state_write_behavior": { "type": "string" },
          "secrets_handling": { "type": "string" },
          "public_safety_notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
